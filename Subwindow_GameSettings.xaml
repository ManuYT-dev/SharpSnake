<!-- Prompt Start: Ändere nichts an der Funktionalität mach nur das es schöner ausschaut-->
<Page x:Class="SnakeSpiel.Subwindow_GameSettings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:SnakeSpiel"
      mc:Ignorable="d"
      Title="Settings" Height="600" Width="800" Background="#1A1A2E">

    <Grid>
        <StackPanel Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="SETTINGS" Foreground="White" FontSize="36" FontFamily="Consolas" 
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <StackPanel Margin="0,0,0,20">
                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Geschwindigkeit" Foreground="#A0A0A0" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ElementName=Speed, Path=Value}" Foreground="White" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>
                <Slider x:Name="Speed" Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,20">
                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Spielfeld Größe" Foreground="#A0A0A0" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ElementName=FieldSize, Path=Value}" Foreground="White" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>
                <Slider x:Name="FieldSize" Minimum="8" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,20">
                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Startlänge Schlange" Foreground="#A0A0A0" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ElementName=InitialLength, Path=Value}" Foreground="White" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>
                <Slider x:Name="InitialLength" Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,20">
                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Essen" Foreground="#A0A0A0" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ElementName=Essen, Path=Value}" Foreground="White" FontFamily="Consolas" FontSize="16" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>
                <Slider x:Name="Essen" Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>

            <Button x:Name="Apply" Content="APPLY &amp; RETURN" Click="Apply_Click"
                    FontFamily="Consolas" FontSize="18" FontWeight="Bold" Foreground="White" Background="#303050" 
                    BorderBrush="#4A4A8A" BorderThickness="2" Padding="10,12" Cursor="Hand">
            </Button>
        </StackPanel>
    </Grid>
</Page>
<!-- Prompt Ende-->
    