<Page x:Class="SnakeSpiel.PauseMenue"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SnakeSpiel"
      mc:Ignorable="d" 
      Title="PauseMenu" Height="600" Width="800" Background="#1A1A2E">

    <Grid>
        <StackPanel Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="PAUSED" Foreground="White" FontSize="48" FontFamily="Consolas" 
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,50"/>

            <Button x:Name="Button_Continue" Content="CONTINUE" Click="Button_Continue_Click"
                    FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="White" Background="#303050" 
                    BorderBrush="#4A4A8A" BorderThickness="2" Padding="10,15" Margin="0,0,0,20" Cursor="Hand"/>

            <Button x:Name="Button_Save" Content="SAVE GAME" Click="Button_Save_Click"
                    FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="White" Background="#303050" 
                    BorderBrush="#4A4A8A" BorderThickness="2" Padding="10,15" Margin="0,0,0,20" Cursor="Hand"/>

            <Button x:Name="Button_MainMenu" Content="MAIN MENU" Click="Button_MainMenu_Click"
                    FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="#FF6B6B" Background="#303050" 
                    BorderBrush="#8A4A4A" BorderThickness="2" Padding="10,15" Cursor="Hand"/>

        </StackPanel>
    </Grid>
</Page>
