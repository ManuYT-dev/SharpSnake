<Page x:Class="SnakeSpiel.Scoreboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SnakeSpiel"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Loaded="Page_Loaded"
      Title="Scoreboard">
    <!-- Erstelle die UI für ein Scoreboard es soll im gleichen Style wie die anderen Pages sein.-->
    <Grid Background="#121212">
        <StackPanel Margin="30">
            <TextBlock Text="TOP 100 SCORES" FontSize="40" Foreground="Cyan" 
                       HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,30">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="10" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <Button Content="ZURÜCK" Click="Back_Click" Margin="0,0,0,30" 
                    Width="180" Height="45" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#333"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Border Background="#1E1E1E" CornerRadius="15" Padding="20" BorderBrush="#333" BorderThickness="1">
                <ScrollViewer MaxHeight="550" VerticalScrollBarVisibility="Hidden">
                    <ItemsControl x:Name="ScoreList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="★ " Foreground="Yellow" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Score}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text=" PTS" Foreground="#888" FontSize="14" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding DateString}" Grid.Column="1" 
                                               Foreground="#666" VerticalAlignment="Center" FontStyle="Italic"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Page>
